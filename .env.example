# Configuración de base de datos Postgres (Supabase)
DATABASE_URL=postgres://user:password@localhost:5432/boletas_db
JWT_SECRET=tu_secreto_jwt
PORT=4000

# Rate limiting (valores de producción por defecto)
# RATE_LIMIT_GLOBAL_MAX=200    # máx requests por ventana de tiempo (toda la API)
# RATE_LIMIT_AUTH_MAX=20       # máx requests por ventana de tiempo (solo /auth/login y /auth/register)
# RATE_LIMIT_WINDOW_MS=900000  # ventana en milisegundos (900000 = 15 min)

# Modo demo: límites muy bajos para demostrar el 429 en clase
# DEMO_MODE=true               # global=10 req/10s, auth=5 req/10s


# Supabase Storage configuration for S3 compatibility
SUPABASE_S3_ENDPOINT=your_supabase_s3_endpoint
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_REGION=us-east-2
S3_BUCKET_NAME=your_s3_bucket_name
SUPABASE_STORAGE_PUBLIC_URL=your_supabase_storage_public_url


